# Template file for 'rebornos'
OSNAME="rebornos"
PRETTY="RebornOS"
BASEDOF="Arch"
DESCRIPTION="Aiming to make Arch Linux as user friendly as possible by providing interface solutions to things you normally have to do in a terminal"
HOMEPAGE="https://rebornos.org"
CREDENTIALS="-"


RELEASES="latest"


function releases_() {
    echo latest
}

function get_() {
    local JSON ISO HASH
    JSON=$(web_pipe "https://meta.cdn.soulharsh007.dev/RebornOS-ISO?format=json") || return 1
    
    echo "DEBUG: JSON response:" >&2
    echo "$JSON" >&2
    jq --version

    # Ověření validního JSONu
    if ! echo "$JSON" | jq . > /dev/null 2>&1; then
        echo "JSON not valid!" >&2
        return 1
    fi

    ISO=$(echo "$JSON" | jq -r ".url")
    HASH=$(echo "$JSON" | jq -r ".md5")

    echo "${ISO} ${HASH}"
}

